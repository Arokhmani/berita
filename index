    <!-- Blogger Skin Section -->
    <b:skin><![CDATA[
        /* Sembunyikan scrollbar bawaan untuk kemulusan navigasi seluler */
        .no-scrollbar::-webkit-scrollbar {
            display: none;
        }
        .no-scrollbar {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
        .transition-all-300 {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        /* Custom reaction popover dengan animasi pop-in lembut */
        .reaction-popover {
            animation: popIn 0.2s cubic-bezier(0.18, 0.89, 0.32, 1.28) forwards;
        }
        @keyframes popIn {
            0% { transform: scale(0.6) translateY(20px); opacity: 0; }
            100% { transform: scale(1) translateY(0); opacity: 1; }
        }
        /* Aturan khusus Blogger Layout Builder Mode */
        body#layout {
            padding-top: 20px;
        }
        body#layout header, body#layout .sidebar-section, body#layout .main-content {
