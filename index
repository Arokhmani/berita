</head>
<body class="bg-gray-100 text-gray-800 font-sans antialiased overflow-x-hidden pb-16 md:pb-0 safe-top">

    <!-- NOTIFIKASI TOAST -->
    <div id="toast" class="fixed bottom-20 md:bottom-5 right-5 z-50 transform translate-y-20 opacity-0 transition-all-300 bg-emerald-600 text-white px-5 py-3 rounded-xl shadow-xl flex items-center gap-2 pointer-events-none">
        <i class="ti ti-circle-check text-xl"></i>
        <span id="toast-text" class="text-sm font-medium">Berhasil!</span>
    </div>

    <!-- HEADER UTAMA -->
    <header class="bg-white fixed top-0 left-0 right-0 z-40 border-b border-gray-100 shadow-xs">
        <div class="max-w-[1250px] mx-auto flex items-center justify-between px-4 h-14">
            <!-- Bagian Judul Website -->
            <div class="flex items-center gap-2" onclick="switchTab('beranda')">
                <span class="font-black text-2xl tracking-tight text-emerald-600 cursor-pointer hover:opacity-90 transition select-none">
                    <b:section id='header-title-sec' maxwidgets='1' showaddelement='no'>
                        <b:widget id='Header1' locked='true' title='Nama Website (Header)' type='Header' version='2'>
                            <b:widget-settings>
                                <b:widget-setting name='displayUrl'/>
                                <b:widget-setting name='displayHeight'>0</b:widget-setting>
                                <b:widget-setting name='sectionWidth'>-1</b:widget-setting>
                                <b:widget-setting name='useImage'>false</b:widget-setting>
                                <b:widget-setting name='shrinkToFit'>false</b:widget-setting>
                                <b:widget-setting name='imagePlacement'>BEHIND</b:widget-setting>
                                <b:widget-setting name='displayWidth'>0</b:widget-setting>
                            </b:widget-settings>
                            <b:includable id='main'>
                                <data:blog.title/>
                            </b:includable>
                        </b:widget>
                    </b:section>
                </span>
            </div>

            <!-- Bagian Kanan: Aksi Cepat (Donasi, Search, Messenger, Menu Garis Tiga) -->
            <div class="flex items-center gap-2">
                <!-- Tombol Donasi dengan pop-up kreatif -->
                <button onclick="openDonationModal('Paperdoll Platform')" class="bg-orange-50 hover:bg-orange-100 text-orange-600 p-2.5 rounded-full transition active:scale-95 relative" title="Donasi &amp; Dukung Kami">
                    <i class="ti ti-gift text-lg animate-bounce"></i>
                    <span class="absolute -top-0.5 -right-0.5 bg-red-500 w-2.5 h-2.5 rounded-full animate-ping"></span>
                    <span class="absolute -top-0.5 -right-0.5 bg-red-500 w-2.5 h-2.5 rounded-full"></span>
                </button>
                <button onclick="focusSearchInput()" class="bg-gray-100 hover:bg-gray-200 text-gray-800 p-2.5 rounded-full transition active:scale-95">
                    <i class="ti ti-search text-lg"></i>
                </button>
                <button onclick="showCartModal()" class="relative bg-gray-100 hover:bg-gray-200 text-gray-800 p-2.5 rounded-full transition active:scale-95">
                    <i class="ti ti-shopping-cart text-lg"></i>
                    <span id="cart-badge" class="absolute -top-1.5 -right-1.5 bg-orange-500 text-white text-[9px] font-bold w-4 h-4 rounded-full flex items-center justify-center border border-white">0</span>
                </button>
                <button onclick="switchTab('menu')" class="bg-gray-100 hover:bg-gray-200 text-gray-800 p-2.5 rounded-full transition active:scale-95 relative">
                    <i class="ti ti-menu-2 text-lg"></i>
                    <span class="absolute top-0 right-0 w-2.5 h-2.5 bg-red-500 rounded-full border border-white"></span>
                </button>
            </div>
        </div>

        <!-- Baris Bawah: Tabs Navigasi Underline Aktif -->
        <nav class="flex justify-around items-center h-12 border-t border-gray-100 text-gray-500 max-w-[1250px] mx-auto">
            <button onclick="switchTab('beranda')" id="tab-beranda" class="flex-1 h-full flex flex-col items-center justify-center border-b-[3px] border-emerald-600 text-emerald-600 transition-all-300 active:bg-gray-50">
                <i class="ti ti-smart-home text-2xl"></i>
            </button>
            <button onclick="switchTab('marketplace')" id="tab-marketplace" class="flex-1 h-full flex flex-col items-center justify-center border-b-[3px] border-transparent hover:text-emerald-500 transition-all-300 active:bg-gray-50">
                <i class="ti ti-building-store text-2xl"></i>
            </button>
            <button onclick="switchTab('grup')" id="tab-grup" class="flex-1 h-full flex flex-col items-center justify-center border-b-[3px] border-transparent hover:text-emerald-500 transition-all-300 active:bg-gray-50">
                <i class="ti ti-users text-2xl"></i>
            </button>
            <button onclick="switchTab('notifikasi')" id="tab-notifikasi" class="flex-1 h-full flex flex-col items-center justify-center border-b-[3px] border-transparent hover:text-emerald-500 transition-all-300 relative active:bg-gray-50">
                <i class="ti ti-bell text-2xl"></i>
                <span id="notif-dot" class="absolute top-2.5 right-6 bg-orange-500 w-2 h-2 rounded-full"></span>
            </button>
            <button onclick="switchTab('profile')" id="tab-profile" class="flex-1 h-full flex flex-col items-center justify-center border-b-[3px] border-transparent active:bg-gray-50">
                <img src="https://images.unsplash.com/photo-1544005313-94ddf0286df2?w=100&amp;h=100&amp;fit=crop" class="w-7 h-7 rounded-full object-cover border-2 border-transparent hover:border-emerald-500 transition-all-300"/>
            </button>
        </nav>
    </header>

    <!-- CONTAINER UTAMA -->
    <div class="max-w-[1250px] mx-auto flex pt-28 min-h-screen">
        
        <!-- SIDEBAR NAVIGATION (Desktop Mode Only) -->
        <aside class="w-[280px] p-4 hidden lg:block overflow-y-auto no-scrollbar flex-shrink-0 bg-white border-r border-gray-150 h-[calc(100vh-112px)] fixed top-28">
            <div class="space-y-6">
                <!-- User Profile Shortcut -->
                <div onclick="switchTab('profile')" class="flex items-center gap-3 p-2 hover:bg-emerald-50 rounded-xl cursor-pointer transition">
                    <img src="https://images.unsplash.com/photo-1544005313-94ddf0286df2?w=100&amp;h=100&amp;fit=crop" class="w-10 h-10 rounded-full border-2 border-emerald-500 object-cover"/>
                    <div>
                        <h4 class="font-bold text-sm text-gray-800">Amel</h4>
                        <p class="text-xs text-emerald-600">Kreator Digital</p>
                    </div>
                </div>

                <div class="space-y-1">
                    <h5 class="text-xs font-bold text-gray-400 uppercase tracking-wider px-3 mb-2">Pintasan Anda</h5>
                    <button onclick="switchTab('beranda')" class="w-full flex items-center gap-3 p-3 text-gray-600 hover:bg-emerald-50/50 hover:text-emerald-700 rounded-xl text-sm font-semibold transition text-left">
                        <i class="ti ti-layout-dashboard text-xl text-emerald-500"></i>
                        <span>Beranda Utama</span>
                    </button>
                    <button onclick="switchTab('marketplace')" class="w-full flex items-center gap-3 p-3 text-gray-600 hover:bg-emerald-50/50 hover:text-emerald-700 rounded-xl text-sm font-semibold transition text-left">
                        <i class="ti ti-building-store text-xl text-orange-500"></i>
                        <span>Pasar Tokopedia Grid</span>
                    </button>
                    <button onclick="switchTab('grup')" class="w-full flex items-center gap-3 p-3 text-gray-600 hover:bg-emerald-50/50 hover:text-emerald-700 rounded-xl text-sm font-semibold transition text-left">
                        <i class="ti ti-users-group text-xl text-blue-500"></i>
                        <span>Grup Komunitas</span>
                    </button>
                    <button onclick="switchTab('menu')" class="w-full flex items-center gap-3 p-3 text-gray-600 hover:bg-emerald-50/50 hover:text-emerald-700 rounded-xl text-sm font-semibold transition text-left">
                        <i class="ti ti-menu-2 text-xl text-purple-500"></i>
                        <span>Semua Menu (Garis 3)</span>
                    </button>
                </div>

                <!-- Bagian CS Support (Bisa diatur melalui Layout Blogger) -->
                <b:section id='sidebar-support' maxwidgets='1' showaddelement='yes'>
                    <b:widget id='HTML10' locked='false' title='CS Support Widget' type='HTML' version='2'>
                        <b:widget-settings>
                            <b:widget-setting name='content'><![CDATA[
                                <div class="p-4 bg-gradient-to-br from-emerald-500 to-emerald-600 text-white rounded-2xl shadow-md">
                                    <h4 class="font-bold text-sm mb-1">Butuh Bantuan?</h4>
                                    <p class="text-xs leading-relaxed mb-3 opacity-90">Hubungi langsung cs admin kami untuk transaksi via WA.</p>
                                    <a href="https://wa.me/6283654488111" target="_blank" class="block text-center bg-white text-emerald-700 font-bold text-xs py-2 rounded-xl hover:bg-emerald-50 transition shadow">Hubungi Kami</a>
                                </div>
                            ]]></b:widget-setting>
                        </b:widget-settings>
                        <b:includable id='main'>
                            <data:content/>
                        </b:includable>
                    </b:widget>
                </b:section>
            </div>
        </aside>

        <!-- MAIN LAYOUT FEED DAN HALAMAN-HALAMAN -->
        <main class="flex-1 lg:ml-[300px] px-3 md:px-6 pb-20 w-full max-w-full overflow-x-hidden">
            
            <!-- FORM PENCARIAN UTAMA -->
            <div id="main-search-wrapper" class="bg-white p-3.5 rounded-2xl shadow-sm border border-gray-100 mb-4">
                <div class="flex items-center gap-3">
                    <img src="https://images.unsplash.com/photo-1544005313-94ddf0286df2?w=80&amp;h=80&amp;fit=crop" class="w-10 h-10 rounded-full object-cover border border-emerald-500"/>
                    <div class="flex-1 relative">
                        <input type="text" id="search-main" oninput="liveSearch()" placeholder="Apa yang kamu cari hari ini? Cari artikel atau produk..." 
                               class="w-full bg-gray-100 hover:bg-gray-200/70 focus:bg-white rounded-full py-2.5 pl-10 pr-4 text-sm font-medium border border-transparent focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-500/20 transition-all-300"/>
                        <i class="ti ti-search absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-400 text-lg"></i>
                    </div>
                </div>
                <!-- Status Info Pencarian Aktif -->
                <div id="search-active-bar" class="hidden mt-3 pt-3 border-t border-gray-100 flex justify-between items-center text-xs">
                    <span class="text-emerald-700 font-bold bg-emerald-50 px-3 py-1 rounded-full flex items-center gap-1.5">
                        <i class="ti ti-filter"></i> Hasil pencarian aktif
                    </span>
                    <button onclick="resetSearch()" class="text-orange-500 font-bold hover:underline">Reset Pencarian</button>
                </div>
            </div>

            <!-- ================= TAB: BERANDA FEED ================= -->
            <div id="content-beranda" class="space-y-4">
                
                <!-- CAROUSEL CUPLIKAN ARTIKEL -->
                <div class="relative mb-4 bg-white p-3 rounded-2xl border border-gray-100 shadow-xs overflow-hidden">
                    <div class="flex justify-between items-center mb-2 px-1">
                        <span class="text-xs font-black text-emerald-700 uppercase tracking-wider flex items-center gap-1 select-none">
                            <i class="ti ti-news text-base"></i> Cuplikan Artikel Populer
                        </span>
                        <span class="text-[10px] text-gray-400 font-bold select-none">Geser Manual <i class="ti ti-arrows-horizontal"></i></span>
                    </div>
                    
                    <div class="flex gap-3 overflow-x-auto no-scrollbar py-1 snap-x scroll-smooth" id="articles-cuplikan-carousel">
                        <!-- Di-generate dinamis oleh JS -->
                    </div>
                </div>

                <!-- FEED DAFTAR ARTIKEL UTAMA (Terintegrasi Postingan Blogger) -->
                <div id="posts-list" class="space-y-4">
                    <b:section id='main-blog-sec' showaddelement='no'>
                        <b:widget id='Blog1' locked='true' title='Postingan Blog' type='Blog' version='2'>
                            <b:includable id='main' var='this'>
                                <b:loop values='data:posts' var='post'>
                                    <article class="post-card bg-white p-4 sm:p-5 rounded-2xl shadow-xs border border-gray-100 transition duration-300 hover:shadow-md" expr:data-keywords='data:post.title' expr:data-id='data:post.id'>
                                        <div class="flex justify-between items-start mb-3">
                                            <div class="flex items-center gap-3">
                                                <b:if cond='data:post.author.authorPhoto'>
                                                    <img expr:src="data:post.author.authorPhoto.image" class="w-10 h-10 rounded-full object-cover border"/>
                                                <b:else/>
                                                    <img src="https://images.unsplash.com/photo-1535713875002-d1d0cf377fde?w=100&amp;h=100&amp;fit=crop" class="w-10 h-10 rounded-full object-cover border"/>
                                                </b:if>
                                                <div>
                                                    <h4 class="font-black text-sm text-gray-900 flex items-center gap-1.5 select-none">
                                                        <data:post.author.name/> <span class="text-blue-600 text-xs font-bold hover:underline cursor-pointer">• Ikuti</span>
                                                    </h4>
                                                    <p class="text-[11px] text-gray-400"><data:post.date/> • <i class="ti ti-world"></i></p>
                                                </div>
                                            </div>
                                        </div>
                                        
                                        <!-- Post Body - Menggunakan kelas click-to-detail untuk Event Delegation bebas error XML -->
                                        <div class="click-to-detail cursor-pointer group" expr:data-id='data:post.id'>
                                            <h3 class="font-black text-base text-gray-900 group-hover:text-emerald-600 transition mb-1"><data:post.title/></h3>
                                            <div class="text-sm text-gray-800 leading-relaxed mb-3">
                                                <data:post.snippet/> <span class="text-emerald-600 font-bold underline text-xs">Baca Selengkapnya</span>
                                            </div>
                                            <b:if cond='data:post.featuredImage'>
                                                <div class="rounded-xl overflow-hidden border border-gray-100 bg-gray-50 aspect-video sm:aspect-auto">
                                                    <img expr:src="data:post.featuredImage" class="w-full object-cover max-h-[300px]"/>
                                                </div>
                                            </b:if>
                                        </div>

                                        <div class="flex justify-between items-center text-xs text-gray-500 border-b border-gray-100 py-3 mt-3 select-none">
                                            <div class="flex items-center gap-1">
                                                <span class="bg-blue-500 text-white rounded-full p-0.5 text-[8px] flex items-center justify-center"><i class="ti ti-thumb-up-filled"></i></span>
                                                <span class="font-bold">128 Suka</span>
                                                <span class="text-gray-300">|</span>
                                                <span class="text-orange-600 font-bold flex items-center gap-0.5">
                                                    <i class="ti ti-gift-filled"></i> <span>5</span> Donatur
                                                </span>
                                            </div>
                                            <!-- Diganti menjadi click-to-detail untuk menghindari quota petik XML -->
                                            <div class="click-to-detail flex gap-2 cursor-pointer hover:underline" expr:data-id='data:post.id'>
                                                <span class="font-bold">Komentar</span>
                                            </div>
                                        </div>

                                        <!-- Aksi Utama - Diintegrasikan menggunakan Class delegasi JS -->
                                        <div class="flex justify-between text-gray-500 font-bold text-xs pt-2 relative gap-1">
                                            <div class="relative flex-1">
                                                <button class="btn-reaction-trigger w-full py-2 flex items-center justify-center gap-1.5 hover:bg-gray-50 rounded-xl transition text-gray-700 font-bold active:scale-95" expr:data-id='data:post.id'>
                                                    <span expr:id='&quot;like-btn-icon-&quot; + data:post.id'><i class="ti ti-thumb-up"></i></span>
                                                    <span expr:id='&quot;like-btn-text-&quot; + data:post.id'>Suka</span>
                                                </button>
                                                <div expr:id='&quot;reaction-popover-&quot; + data:post.id' class="absolute bottom-11 left-1/2 -translate-x-1/2 bg-white shadow-2xl border rounded-full px-2 py-1.5 hidden flex items-center gap-2.5 z-50 reaction-popover">
                                                    <button class="btn-reaction-select transform hover:scale-130 transition text-lg" expr:data-id='data:post.id' data-reaction="like" data-emoji="👍" data-color="text-blue-500">👍</button>
                                                    <button class="btn-reaction-select transform hover:scale-130 transition text-lg" expr:data-id='data:post.id' data-reaction="love" data-emoji="❤️" data-color="text-red-500">❤️</button>
                                                    <button class="btn-reaction-select transform hover:scale-130 transition text-lg" expr:data-id='data:post.id' data-reaction="care" data-emoji="🥰" data-color="text-yellow-500">🥰</button>
                                                    <button class="btn-reaction-select transform hover:scale-130 transition text-lg" expr:data-id='data:post.id' data-reaction="haha" data-emoji="😆" data-color="text-yellow-500">😆</button>
                                                    <button class="btn-reaction-select transform hover:scale-130 transition text-lg" expr:data-id='data:post.id' data-reaction="wow" data-emoji="😮" data-color="text-yellow-500">😮</button>
                                                    <button class="btn-reaction-select transform hover:scale-130 transition text-lg" expr:data-id='data:post.id' data-reaction="sad" data-emoji="😢" data-color="text-blue-400">😢</button>
                                                </div>
                                            </div>

                                            <button class="click-to-detail flex-1 py-2 flex items-center justify-center gap-1 hover:bg-gray-50 rounded-xl transition active:scale-95" expr:data-id='data:post.id'><i class="ti ti-message"></i> Komen</button>
                                            <button expr:onclick='&quot;openDonationModal(\&quot;&quot; + data:post.author.name + &quot;\&quot;)&quot;' class="flex-1 py-2 flex items-center justify-center gap-1 hover:bg-gray-50 rounded-xl transition text-orange-600 active:scale-95"><i class="ti ti-gift text-sm"></i> Donasi</button>
                                            <button expr:onclick='&quot;nativeShare(\&quot;&quot; + data:post.title + &quot;\&quot;, \&quot;&quot; + data:post.url + &quot;\&quot;)&quot;' class="flex-1 py-2 flex items-center justify-center gap-1 hover:bg-gray-50 rounded-xl transition active:scale-95"><i class="ti ti-share"></i> Bagikan</button>
                                        </div>
                                    </article>
                                </b:loop>
                            </b:includable>
                        </b:widget>
                    </b:section>
                </div>
            </div>

            <!-- ================= TAB: MARKETPLACE (2 KOLOM) ================= -->
            <div id="content-marketplace" class="hidden space-y-4">
                <div class="bg-white p-4 rounded-2xl shadow-sm border border-gray-150 flex justify-between items-center">
                    <div>
                        <h2 class="font-black text-lg text-emerald-700">Pasar Belanja Modern</h2>
                        <p class="text-xs text-gray-400">Checkout otomatis langsung ke WhatsApp Admin</p>
                    </div>
                    <span class="bg-orange-100 text-orange-600 font-bold text-xs px-2.5 py-1 rounded-full">Bebas Ongkir</span>
                </div>

                <div id="products-grid" class="grid grid-cols-2 gap-3 md:gap-4">
                    <!-- Produk Tokopedia Style -->
                    <div class="product-card bg-white rounded-2xl overflow-hidden shadow-xs border border-gray-150 flex flex-col justify-between group hover:shadow-md transition duration-300" data-keywords="sepatu sneaker lari olahraga hijau">
