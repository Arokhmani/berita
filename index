        function updateCartUI() {
            const badge = document.getElementById('cart-badge');
            const container = document.getElementById('cart-items-container');
            const totalDisplay = document.getElementById('cart-total-price');
            let totalQty = 0;
            let totalPrice = 0;

            container.innerHTML = "";

            if (cart.length === 0) {
                container.innerHTML = "<p class='text-gray-400 text-center py-6 text-sm'>Keranjang Anda masih kosong.</p>";
                badge.textContent = "0";
                totalDisplay.textContent = "Rp 0";
                return;
            }

            cart.forEach((item, index) => {
                totalQty += item.qty;
                totalPrice += (item.price * item.qty);

                const div = document.createElement('div');
                div.className = "flex justify-between items-center bg-gray-50 p-2.5 rounded-xl border";
                div.innerHTML = `
                    <div class="min-w-0 flex-1">
                        <h5 class="text-xs font-bold text-gray-800 truncate">${item.name}</h5>
                        <p class="text-[10px] text-gray-500">Rp ${item.price.toLocaleString('id-ID')} x ${item.qty}</p>
                    </div>
                    <div class="flex items-center gap-2">
                        <button onclick="changeQty(${index}, -1)" class="bg-gray-200 hover:bg-gray-300 w-6 h-6 rounded text-xs font-bold">-</button>
                        <span class="text-xs font-bold">${item.qty}</span>
                        <button onclick="changeQty(${index}, 1)" class="bg-gray-200 hover:bg-gray-300 w-6 h-6 rounded text-xs font-bold">+</button>
                    </div>
                `;
                container.appendChild(div);
            });

            badge.textContent = totalQty;
            totalDisplay.textContent = "Rp " + totalPrice.toLocaleString('id-ID');
        }

        function changeQty(index, val) {
