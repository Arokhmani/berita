        // Penyaringan pencarian real-time
        function liveSearch() {
            const query = searchInput.value.trim().toLowerCase();
            const postCards = document.querySelectorAll('.post-card');
            const productCards = document.querySelectorAll('.product-card');

            if (query === "") {
                resetSearch();
                return;
            }
            searchActiveBar.classList.remove('hidden');

            if (currentTab === 'beranda') {
                postCards.forEach(card => {
                    const text = card.textContent.toLowerCase();
                    card.style.display = text.includes(query) ? 'block' : 'none';
                });
            } else if (currentTab === 'marketplace') {
                productCards.forEach(card => {
                    const keywords = card.getAttribute('data-keywords').toLowerCase();
                    const title = card.querySelector('h4').textContent.toLowerCase();
                    card.style.display = (keywords.includes(query) || title.includes(query)) ? 'flex' : 'none';
                });
            }
        }

        function resetSearch() {
            searchInput.value = "";
            searchActiveBar.classList.add('hidden');
            const postCards = document.querySelectorAll('.post-card');
            const productCards = document.querySelectorAll('.product-card');
            postCards.forEach(card => card.style.display = 'block');
            productCards.forEach(card => card.style.display = 'flex');
        }

        // Fungsi Perpindahan Tab Utama
        function switchTab(tabId) {
            currentTab = tabId;
            resetSearch();

            document.getElementById('content-beranda').classList.add('hidden');
            document.getElementById('content-marketplace').classList.add('hidden');
            document.getElementById('content-grup').classList.add('hidden');
            document.getElementById('content-notifikasi').classList.add('hidden');
            document.getElementById('content-profile').classList.add('hidden');
            document.getElementById('content-menu').classList.add('hidden');
            document.getElementById('content-article-detail').classList.add('hidden');
            document.getElementById('content-info-page').classList.add('hidden');

            document.getElementById('content-' + tabId).classList.remove('hidden');

            const tabs = ['beranda', 'marketplace', 'grup', 'notifikasi', 'profile'];
            tabs.forEach(t => {
                const tabBtn = document.getElementById('tab-' + t);
                const mobileTabBtn = document.getElementById('mobile-tab-' + t);
                if (tabBtn) {
                    if (t === tabId) {
                        tabBtn.classList.add('border-emerald-600', 'text-emerald-600');
                        tabBtn.classList.remove('border-transparent', 'text-gray-400');
                    } else {
                        tabBtn.classList.add('border-transparent', 'text-gray-400');
                        tabBtn.classList.remove('border-emerald-600', 'text-emerald-600');
                    }
                }
                if (mobileTabBtn) {
                    if (t === tabId) {
                        mobileTabBtn.classList.add('text-emerald-600');
                        mobileTabBtn.classList.remove('text-gray-400');
                    } else {
                        mobileTabBtn.classList.add('text-gray-400');
                        mobileTabBtn.classList.remove('text-emerald-600');
                    }
                }
            });

            if (tabId === 'notifikasi') {
                document.getElementById('notif-dot').classList.add('hidden');
            }
        }

        function selectReaction(postId, reactionKey, emoji, textColorClass) {
            postId = String(postId);
            const iconId = postId === 'detail' ? 'like-btn-icon-detail' : 'like-btn-icon-' + postId;
            const textId = postId === 'detail' ? 'like-btn-text-detail' : 'like-btn-text-' + postId;
            
            const btnIcon = document.getElementById(iconId);
            const btnText = document.getElementById(textId);
            
            if (btnIcon && btnText) {
                btnIcon.innerHTML = "<span class='text-lg'>" + emoji + "</span>";
                btnText.innerHTML = "<span class='" + textColorClass + "'>" + reactionKey.toUpperCase() + "</span>";
            }
            
            const popover = document.getElementById('reaction-popover-' + postId);
            if (popover) {
                popover.classList.add('hidden');
            }

            if (postId === 'detail' || postId === currentArticleOpen) {
                const data = articlesDB[currentArticleOpen];
                if (data) {
                    data.likes += 1;
                    const likesDisplay = document.getElementById('detail-likes-display');
                    if (likesDisplay) likesDisplay.textContent = data.likes + " Suka";
                }
            }

            showNotification("Menanggapi dengan reaksi " + emoji);
        }

