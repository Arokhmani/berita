        // Global Event Delegation yang sangat aman dari error Xml Blogger
        document.addEventListener('click', function(e) {
            // 1. Delegasi klik untuk buka detail artikel
            const clickable = e.target.closest('.click-to-detail');
            if (clickable) {
                const postId = clickable.getAttribute('data-id');
                if (postId) {
                    openArticleDetail(postId);
                    return;
                }
            }

            // 2. Delegasi klik untuk memicu Reaction Popover
            const trigger = e.target.closest('.btn-reaction-trigger');
            if (trigger) {
                e.stopPropagation();
                const postId = trigger.getAttribute('data-id');
                const popover = document.getElementById('reaction-popover-' + postId);
                if (popover) {
                    popover.classList.toggle('hidden');
                }
                return;
            }

            // 3. Delegasi klik untuk memilih reaksi
            const selection = e.target.closest('.btn-reaction-select');
            if (selection) {
                e.stopPropagation();
                const postId = selection.getAttribute('data-id');
                const reaction = selection.getAttribute('data-reaction');
                const emoji = selection.getAttribute('data-emoji');
                const color = selection.getAttribute('data-color');
                selectReaction(postId, reaction, emoji, color);
                return;
            }
        });

