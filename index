                avatar: "https://images.unsplash.com/photo-1544005313-94ddf0286df2?w=100&amp;h=100&amp;fit=crop",
                text: txt,
                time: "Baru saja",
                reaction: "",
                replies: []
            };

            articlesDB[currentArticleOpen].comments.push(newComment);
            input.value = "";
