        window.onload = () => {
            parseBloggerPostsToLocalDB();
            renderCuplikanCarousel();
            renderAllArticlesList();
            renderProfileTabMedia();

            if ('serviceWorker' in navigator) {
                try {
                    navigator.serviceWorker.register('./sw.js')
                    .then(reg => {
                        console.log('PWA aktif:', reg.scope);
                    })
                    .catch(err => {
                        console.warn('Registrasi Service Worker dilewati di sandbox:', err.message);
                    });
                } catch (e) {
                    console.warn('PWA tidak didukung di lingkungan sandbox ini:', e.message);
                }
            }
        };
